{
  "name": "galactic-spacefarer-manager",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-spacefarer-manager": "cds watch --open com.spacefederation.spacefarers.spacefarermanager/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/spacefederation.sqlite"
        }
      },
      "auth": {
        "kind": "mocked",
        "users": {
          "techelek": {
            "password": "techelek",
            "roles": [
              "admin"
            ],
            "attr": {
              "originPlanet": "Mars"
            }
          },
          "mezgageza": {
            "password": "mezgageza",
            "roles": [
              "user"
            ],
            "attr": {
              "originPlanet": "Earth"
            }
          }
        }
      }
    }
  },
  "private": false,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/spacefarer-manager"
  ]
}
